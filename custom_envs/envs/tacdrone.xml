<mujoco model="TacDrone">

    <option timestep="0.01" gravity="0 0 -9.81" integrator="RK4">
    </option>

    <statistic center="0 0 1" extent="8"/>

    <visual>
        <global azimuth="0" elevation="-20" fovy="70"/>
    </visual>

    <default>
        <geom solref="-1000 -50" solimp="0.9 0.95 0.001 0.5 2" condim="3" friction="0.5 0.005 0.0001"/>
    </default>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.55 0.14 0.29" rgb2="0.92 0.73 0.22"
            markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.1" rgba="1 1 1 0.6"/>
    </asset>

    <worldbody>
        <light name="spotlight" mode="targetbodycom" target="TD" pos="0 -1 2"/>
        <geom name="floor" size="5 5 0.05" pos="0 0 0" type="plane" material="groundplane" condim="3"/>
        <body name="TD" pos="0 0 0.135">
            <freejoint/>
            <camera name="track" pos="0 -2.5 -2.5" xyaxes="1 0 0 0 0.707 0.707" mode="trackcom"/>
            <site name="imu" pos="0 0 0.03"/>
            <inertial pos="0 0 0" mass="1.883" diaginertia="0.01355 0.01562 0.0267"/>
            <geom name="chassis" type="box" size=".1275 .1275 .135" rgba="40 40 40 1"/>
            <geom name="rotor1" type="sphere" size="0.1" pos=".159 -.159 .135" rgba=".90 .43 .16 .75"/>
            <geom name="rotor2" type="sphere" size="0.1" pos="-.159 .159 .135" rgba=".16 .90 .51 .75"/>
            <geom name="rotor3" type="sphere" size="0.1" pos=".159 .159 .135" rgba=".90 .43 .16 .75"/>
            <geom name="rotor4" type="sphere" size="0.1" pos="-.159 -.159 .135" rgba=".16 .90 .51 .75"/>
            <site name="thrust1" pos=".159 -.159 .135"/>
            <site name="thrust2" pos="-.159 .159 .135"/>
            <site name="thrust3" pos=".159 .159 .135"/>
            <site name="thrust4" pos="-.159 -.159 .135"/>
        </body>
    </worldbody>

    <actuator>
        <motor name="thrust1" site="thrust1" forcelimited="true" forcerange="0 10" gear="0 0 1 0 0 -.0167"/>
        <motor name="thrust2" site="thrust2" forcelimited="true" forcerange="0 10" gear="0 0 1 0 0 -.0167"/>
        <motor name="thrust3" site="thrust3" forcelimited="true" forcerange="0 10" gear="0 0 1 0 0 .0167"/>
        <motor name="thrust4" site="thrust4" forcelimited="true" forcerange="0 10" gear="0 0 1 0 0 .0167"/>
    </actuator>

    <sensor>
        <gyro name="body_gyro" site="imu"/>
        <accelerometer name="body_accel" site="imu"/>
        <framequat name="body_quat" objtype="site" objname="imu"/>
    </sensor>

</mujoco>
